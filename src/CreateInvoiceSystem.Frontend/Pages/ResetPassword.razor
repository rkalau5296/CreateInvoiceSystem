@page "/reset-password"
@using System.ComponentModel.DataAnnotations
@using System.Text.Json
@using CreateInvoiceSystem.Frontend.Models
@using Microsoft.AspNetCore.Authorization
@using CreateInvoiceSystem.Frontend.Services
@using CreateInvoiceSystem.Frontend.Components
@attribute [AllowAnonymous]
@inject NavigationManager Navigation
@inject AuthService AuthService

<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card shadow-sm" style="width: 100%; max-width: 400px;">
        <div class="card-body p-4">
            <h3 class="card-title text-center mb-4">Ustaw nowe hasło</h3>

            @if (_isSuccess)
            {
                <div class="alert alert-success">Hasło zostało zmienione.</div>
                <button class="btn btn-primary w-100" @onclick='(() => Navigation.NavigateTo("/login"))'>Zaloguj się</button>
            }
            else
            {
                <ValidatedEditForm TModel="ResetPasswordViewModel" Model="_model" OnValidSubmit="HandleReset" OnInvalidSubmit="HandleInvalidSubmit" @ref="formRef">
                    <ValidatedInputText @bind-Value="_model.Password" Type="password" Label="Nowe hasło" />
                    <ValidatedInputText @bind-Value="_model.ConfirmPassword" Type="password" Label="Powtórz hasło" />

                    @if (!string.IsNullOrEmpty(_errorMessage))
                    {
                        <div class="alert alert-danger small">@_errorMessage</div>
                    }

                    <button type="submit" class="btn btn-success w-100" disabled="@_isProcessing">
                        @if (_isProcessing)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Zmień hasło
                    </button>
                </ValidatedEditForm>
            }
        </div>
    </div>
</div>

@code {
    private ResetPasswordViewModel _model = new();
    private bool _isProcessing;
    private bool _isSuccess;
    private string? _errorMessage;

    private ValidatedEditForm<ResetPasswordViewModel>? formRef;

    [Parameter][SupplyParameterFromQuery] public string? Token { get; set; }
    [Parameter][SupplyParameterFromQuery] public string? Email { get; set; }
    [Parameter][SupplyParameterFromQuery] public string? Version { get; set; }

    private void HandleInvalidSubmit(EditContext context)
    {
        _errorMessage = "Uzupełnij wymagane pola.";
    }

    private static string NormalizeFieldName(string original)
    {
        if (string.IsNullOrWhiteSpace(original))
            return original ?? string.Empty;

        var parts = original.Split(new[] { '.', '_', '/' }, StringSplitOptions.RemoveEmptyEntries);
        for (int i = 0; i < parts.Length; i++)
        {
            var p = parts[i];
            if (p.Length == 0) continue;
            parts[i] = char.ToUpperInvariant(p[0]) + (p.Length > 1 ? p.Substring(1) : string.Empty);
        }
        return string.Join('.', parts);
    }

    private string FormatErrorMessage(string? rawMessage)
    {
        if (string.IsNullOrWhiteSpace(rawMessage))
            return "Błąd: Wystąpił nieoczekiwany problem.";

        string msgToParse = rawMessage.Trim();

        if (msgToParse.StartsWith("Błąd:"))
        {
            msgToParse = msgToParse.Substring(5).Trim();
        }

        try
        {
            if (msgToParse.StartsWith("{") && msgToParse.EndsWith("}"))
            {
                using var doc = JsonDocument.Parse(msgToParse);
                if (doc.RootElement.TryGetProperty("message", out var msgProp))
                {
                    return $"Błąd: {msgProp.GetString()}";
                }
            }
        }
        catch
        {
        }

        var sanitized = ApiExceptionExtensions.SanitizeMessage(rawMessage);
        return sanitized.StartsWith("Błąd") ? sanitized : $"Błąd: {sanitized}";
    }

    private async Task HandleReset()
    {
        formRef?.ClearServerErrors();
        formRef?.EditContext?.NotifyValidationStateChanged();

        _errorMessage = null;

        if (string.IsNullOrEmpty(Token) || string.IsNullOrEmpty(Email) || string.IsNullOrEmpty(Version))
        {
            _errorMessage = "Brak tokena, adresu email lub wersji resetu.";
            return;
        }

        _isProcessing = true;

        try
        {
            var result = await AuthService.ResetPasswordAsync(Email, Token, Version, _model.Password);

            if (result != null && result.IsSuccess)
            {
                _isSuccess = true;
                return;
            }

            _errorMessage = FormatErrorMessage(result?.Message);
        }
        catch (ApiException aex)
        {
            bool addedAny = false;

            if (!string.IsNullOrWhiteSpace(aex.Response))
            {
                try
                {
                    using var doc = JsonDocument.Parse(aex.Response);
                    if (doc.RootElement.TryGetProperty("errors", out var errorsElement) && errorsElement.ValueKind == JsonValueKind.Object)
                    {
                        foreach (var prop in errorsElement.EnumerateObject())
                        {
                            var rawField = prop.Name;
                            var fieldName = NormalizeFieldName(rawField);
                            foreach (var msgElem in prop.Value.EnumerateArray())
                            {
                                var fieldMsg = msgElem.GetString() ?? "Błąd walidacji";
                                formRef?.AddServerError(fieldName, fieldMsg);
                                addedAny = true;
                            }
                        }

                        if (addedAny)
                        {
                            formRef?.EditContext?.NotifyValidationStateChanged();
                            _isProcessing = false;
                            return;
                        }
                    }
                }
                catch
                {
                }
            }

            _errorMessage = FormatErrorMessage(aex.Response ?? aex.GetUserMessage());
        }
        catch (Exception ex)
        {
            _errorMessage = FormatErrorMessage(ex.Message);
        }
        finally
        {
            _isProcessing = false;
            StateHasChanged();
        }
    }
}