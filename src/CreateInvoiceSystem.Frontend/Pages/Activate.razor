@page "/activate"
@using System.Text.Json
@using CreateInvoiceSystem.Frontend.Models
@using CreateInvoiceSystem.Frontend.Services
@inject HttpClient Http
@inject NavigationManager Navigation
@using Microsoft.AspNetCore.Authorization
@attribute [AllowAnonymous]

<h3>Aktywacja konta</h3>

@if (_isProcessing)
{
    <p>Proszę czekać, aktywujemy Twoje konto...</p>
}
else
{
    <div class="alert @(_isSuccess ? "alert-success" : "alert-danger")">
        @_message
    </div>

    @if (_isSuccess)
    {
        <button class="btn btn-primary" @onclick='() => Navigation.NavigateTo("/login")'>Zaloguj się</button>
    }
}

@code {
    [Parameter][SupplyParameterFromQuery] public string? Token { get; set; }

    private bool _isProcessing = true;
    private bool _isSuccess;
    private string _message = "";

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(Token))
        {
            _isSuccess = false;
            _message = "Brak tokena aktywacyjnego.";
            _isProcessing = false;
            return;
        }

        try
        {
            var response = await Http.GetAsync($"api/Auth/activate?token={Token}");
            var content = await response.Content.ReadAsStringAsync();

            var options = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            ServerActivateResponse? srv = null;
            if (!string.IsNullOrWhiteSpace(content))
            {
                try
                {
                    srv = System.Text.Json.JsonSerializer.Deserialize<ServerActivateResponse>(content, options);
                }
                catch
                {
                }
            }

            if (srv != null)
            {
                _isSuccess = srv.IsSuccess;
                _message = !string.IsNullOrWhiteSpace(srv.Message)
                    ? srv.Message
                    : (!string.IsNullOrWhiteSpace(srv.Detail) ? srv.Detail : (!string.IsNullOrWhiteSpace(srv.Title) ? srv.Title : (srv.IsSuccess ? "Konto zostało pomyślnie aktywowane!" : "Link wygasł lub jest nieprawidłowy.")));
            }
            else
            {
                string serverMsg = string.Empty;
                if (!string.IsNullOrWhiteSpace(content))
                {
                    try
                    {
                        using var doc = System.Text.Json.JsonDocument.Parse(content);
                        var root = doc.RootElement;

                        if (root.TryGetProperty("detail", out var d) && d.ValueKind == System.Text.Json.JsonValueKind.String)
                            serverMsg = d.GetString() ?? string.Empty;
                        else if (root.TryGetProperty("title", out var t) && t.ValueKind == System.Text.Json.JsonValueKind.String)
                            serverMsg = t.GetString() ?? string.Empty;
                        else if (root.TryGetProperty("errors", out var errors) && errors.ValueKind == System.Text.Json.JsonValueKind.Object)
                        {
                            var sb = new System.Text.StringBuilder();
                            foreach (var prop in errors.EnumerateObject())
                            {
                                foreach (var item in prop.Value.EnumerateArray())
                                {
                                    var s = item.GetString();
                                    if (!string.IsNullOrWhiteSpace(s))
                                    {
                                        if (sb.Length > 0) sb.Append(" ; ");
                                        sb.Append(s);
                                    }
                                }
                            }
                            if (sb.Length > 0) serverMsg = sb.ToString();
                        }
                        else
                        {
                            serverMsg = content;
                        }
                    }
                    catch
                    {
                        serverMsg = content;
                    }
                }

                if (response.IsSuccessStatusCode)
                {
                    _isSuccess = true;
                    _message = !string.IsNullOrWhiteSpace(serverMsg) ? serverMsg : "Konto zostało pomyślnie aktywowane!";
                }
                else
                {
                    if (!string.IsNullOrWhiteSpace(serverMsg))
                    {
                        var sanitized = ApiExceptionExtensions.SanitizeMessage(serverMsg);
                        _isSuccess = false;
                        _message = sanitized.StartsWith("Błąd") ? sanitized : $"Błąd: {sanitized}";
                    }
                    else
                    {
                        _isSuccess = false;
                        _message = "Link wygasł lub jest nieprawidłowy.";
                    }
                }
            }
        }
        catch (ApiException aex)
        {
            var userMessage = aex.GetUserMessage();
            _isSuccess = false;
            _message = userMessage.StartsWith("Błąd") ? userMessage : $"Błąd: {userMessage}";
        }
        catch (Exception ex)
        {
            var sanitized = ApiExceptionExtensions.SanitizeMessage(ex.Message);
            _isSuccess = false;
            _message = sanitized.StartsWith("Błąd") ? sanitized : $"Błąd: {sanitized}";
        }
        finally
        {
            _isProcessing = false;
        }
    }
}