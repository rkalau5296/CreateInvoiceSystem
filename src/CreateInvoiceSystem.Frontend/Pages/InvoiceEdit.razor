@page "/invoices/edit/{Id:int}"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms
@using CreateInvoiceSystem.Frontend.Models
@using CreateInvoiceSystem.Frontend.Services
@using CreateInvoiceSystem.Frontend.Components
@inject InvoiceService InvoiceService
@inject ClientService ClientService
@inject ProductService ProductService
@inject NavigationManager Navigation
@implements IDisposable

<div class="container my-5">
    @if (_isLoading)
    {
        <div class="text-center p-5">
            <div class="spinner-border text-primary"></div>
            <p>Ładowanie danych faktury...</p>
        </div>
    }
    else
    {
        <div class="d-flex justify-content-between mb-4">
            <h3>Tryb Edycji: @_invoice.Title</h3>
            <div>
                <button class="btn btn-secondary me-2 shadow-sm" @onclick='() => Navigation.NavigateTo("/invoices")'>Anuluj</button>
            </div>
        </div>

        <ValidatedEditForm @ref="_validatedForm"
                           TModel="InvoiceDto"
                           Model="_invoice"
                           OnValidSubmit="OnSubmitUpdate"
                           OnInvalidSubmit="OnInvalidSubmitHandler"
                           OnEditContextInitialized="OnEditContextInitialized">
            <div class="invoice-box p-5 border shadow bg-white">
                <div class="row mb-5">
                    <div class="col-6">
                        <label class="small text-muted fw-bold">Numer faktury: <span class="text-danger">*</span></label>
                        <ValidatedInputText @bind-Value="_invoice.Title" Placeholder="np. FV 01/2026" />
                    </div>
                    <div class="col-6 text-end">
                        <div class="mb-2">
                            <label class="small text-muted fw-bold">Data wystawienia: <span class="text-danger">*</span></label>
                            <InputDate @bind-Value="_invoice.CreatedDate" class="@($"form-control form-control-sm d-inline-block w-auto ms-2 {GetFieldClass(() => _invoice.CreatedDate)}")" />
                            <ValidationMessage For="@(() => _invoice.CreatedDate)" class="text-danger small" />
                        </div>
                        <div class="mb-2">
                            <label class="small text-muted fw-bold">Termin płatności: <span class="text-danger">*</span></label>
                            <InputDate @bind-Value="_invoice.PaymentDate" class="@($"form-control form-control-sm d-inline-block w-auto ms-2 {GetFieldClass(() => _invoice.PaymentDate)}")" />
                            <ValidationMessage For="@(() => _invoice.PaymentDate)" class="text-danger small" />
                        </div>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Metoda płatności <span class="text-danger">*</span></label>
                        <InputSelect @bind-Value="_invoice.MethodOfPayment" class="@($"form-select {GetFieldClass(() => _invoice.MethodOfPayment)}")">
                            <option value="">-- Wybierz --</option>
                            <option value="Przelew">Przelew</option>
                            <option value="Gotówka">Gotówka</option>
                            <option value="BLIK">BLIK</option>
                            <option value="Karta">Karta</option>
                        </InputSelect>
                        <ValidationMessage For="@(() => _invoice.MethodOfPayment)" class="text-danger small" />
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-12">
                        <label class="form-label fw-bold">Uwagi / Komentarz</label>
                        <InputTextArea @bind-Value="_invoice.Comments" class="@($"form-control {GetFieldClass(() => _invoice.Comments)}")" rows="3" />
                    </div>
                </div>

                <div class="row mb-5">
                    <div class="col-6">
                        <h6 class="text-uppercase fw-bold border-bottom pb-2 mb-3 text-muted">Sprzedawca</h6>

                        <label class="small text-muted">Nazwa sprzedawcy: <span class="text-danger">*</span></label>
                        <ValidatedInputText @bind-Value="_invoice.SellerName" Placeholder="Nazwa sprzedawcy" />

                        <label class="small text-muted">Adres sprzedawcy: <span class="text-danger">*</span></label>
                        <textarea value="@_invoice.SellerAddress"
                                  @oninput="OnSellerAddressInput"
                                  class="@($"form-control mb-1 {GetFieldClass(() => _invoice.SellerAddress)}")"
                                  rows="2"
                                  placeholder="Adres (ulica, nr, miasto)"></textarea>
                        <ValidationMessage For="@(() => _invoice.SellerAddress)" class="text-danger small" />

                        <label class="small text-muted">NIP sprzedawcy: <span class="text-danger">*</span></label>
                        <ValidatedInputText @bind-Value="_invoice.SellerNip" Placeholder="NIP sprzedawcy" />
                    </div>

                    <div class="col-6">
                        <h6 class="text-uppercase fw-bold border-bottom pb-2 mb-3 text-primary">Nabywca</h6>

                        <label class="small text-muted">Nazwa nabywcy: <span class="text-danger">*</span></label>
                        <input list="clientOptions"
                               value="@_invoice.ClientName"
                               class="@($"form-control mb-1 fw-bold {GetFieldClass(() => _invoice.ClientName)}")"
                               @oninput="OnClientNameInput"
                               placeholder="Wpisz nazwę klienta..." />
                        <ValidationMessage For="@(() => _invoice.ClientName)" class="text-danger small" />

                        <label class="small text-muted">Adres nabywcy: <span class="text-danger">*</span></label>
                        <textarea value="@_invoice.ClientAddress"
                                  @oninput="OnClientAddressInput"
                                  class="@($"form-control mb-1 {GetFieldClass(() => _invoice.ClientAddress)}")"
                                  rows="2"
                                  placeholder="Adres (ulica, nr, miasto)"></textarea>
                        <ValidationMessage For="@(() => _invoice.ClientAddress)" class="text-danger small" />

                        <label class="small text-muted">NIP nabywcy: <span class="text-danger">*</span></label>
                        <ValidatedInputText @bind-Value="_invoice.ClientNip" Placeholder="NIP" />

                        <label class="small text-muted">Email nabywcy:</label>
                        <InputText @bind-Value="_invoice.ClientEmail" class="form-control" placeholder="Email" />
                    </div>
                </div>

                <div class="mb-4">
                    @{
                        var posField = new FieldIdentifier(_invoice, nameof(_invoice.InvoicePositions));
                        var posErrors = _editContext?.GetValidationMessages(posField) ?? Enumerable.Empty<string>();
                    }
                    @if (posErrors.Any())
                    {
                        <div class="alert alert-danger small">
                            @foreach (var msg in posErrors)
                            {
                                <div>@msg</div>
                            }
                        </div>
                    }

                    <h5 class="mb-3 text-secondary">Pozycje na fakturze</h5>

                    <div class="table-responsive">
                        <table class="table table-bordered align-middle">
                            <thead class="table-dark text-center small">
                                <tr>
                                    <th style="width: 50px">Lp.</th>
                                    <th>Produkt / Opis</th>
                                    <th style="width: 80px">Ilość <span class="text-danger">*</span></th>
                                    <th style="width: 140px">Cena netto <span class="text-danger">*</span></th>
                                    <th style="width: 100px">VAT</th>
                                    <th style="width: 130px">Kwota VAT</th>
                                    <th style="width: 150px">Wartość BRUTTO</th>
                                    <th style="width: 100px">Akcje</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < _invoice.InvoicePositions.Count; i++)
                                {
                                    var idx = i;
                                    var pos = _invoice.InvoicePositions[idx];
                                    <tr @key="pos">
                                        <td class="text-center">@(idx + 1)</td>
                                        <td>
                                            <input list="productOptions"
                                                   value="@pos.ProductName"
                                                   class="@($"form-control mb-1 fw-bold {GetFieldClass(() => pos.ProductName)}")"
                                                   @oninput="(ChangeEventArgs e) => OnProductNameInput(e, pos)"
                                                   placeholder="Nazwa produktu..." />
                                            <ValidationMessage For="@(() => pos.ProductName)" class="text-danger small" />

                                            <InputTextArea @bind-Value="pos.ProductDescription"
                                                           class="@($"form-control form-control-sm mt-2 {GetFieldClass(() => pos.ProductDescription)}")"
                                                           placeholder="Opis pozycji..." />
                                        </td>
                                        <td>
                                            <ValidatedInputNumber TValue="int"
                                                                  @bind-Value="pos.Quantity"
                                                                  AdditionalAttributes="@_minOneAttributes"
                                                                  CssClass="@($"form-control text-center {GetFieldClass(() => pos.Quantity)}")" />
                                        </td>
                                        <td>
                                            <ValidatedInputNumber TValue="decimal?"
                                                                  @bind-Value="pos.ProductValue"
                                                                  CssClass="@($"form-control text-end {GetFieldClass(() => pos.ProductValue)}")"
                                                                  Step="0.01"
                                                                  AdditionalAttributes="@_priceAttributes" />
                                        </td>
                                        <td>
                                            <select @bind="pos.VatRate" class="form-select">
                                                <option value="23%">23%</option>
                                                <option value="8%">8%</option>
                                                <option value="5%">5%</option>
                                                <option value="0%">0%</option>
                                                <option value="zw">zw</option>
                                            </select>
                                        </td>
                                        <td class="text-end">@CalculatePositionVat(pos).ToString("N2")</td>
                                        <td class="text-end fw-bold">@CalculatePositionGross(pos).ToString("N2")</td>
                                        <td class="text-center">
                                            <button type="button" class="btn btn-sm btn-danger px-3 shadow-sm" @onclick="() => RemovePositionWithClear(pos)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <button type="button" class="btn btn-outline-secondary btn-sm w-100 mt-2" @onclick="AddPosition">
                        <i class="bi bi-plus-lg"></i> Dodaj kolejną pozycję
                    </button>
                </div>

                <div class="row mt-4">
                    <div class="col-md-12 text-end mb-4">
                        <div class="p-3 bg-light rounded d-inline-block border text-end" style="min-width: 300px;">
                            <div class="text-muted">Suma netto: @CalculateTotalNet().ToString("N2") PLN</div>
                            <div class="text-muted mb-1">Suma VAT: @CalculateTotalVat().ToString("N2") PLN</div>
                            <h3 class="mb-0 text-primary fw-bold">RAZEM (Brutto): @CalculateTotalGross().ToString("N2") PLN</h3>
                        </div>
                    </div>
                </div>

                <div class="text-end mt-4">
                    <button type="submit" class="btn btn-primary shadow">Zapisz zmiany</button>
                </div>
            </div>
        </ValidatedEditForm>
    }
</div>

<datalist id="clientOptions">
    @foreach (var c in _availableClients)
    {
        <option value="@c.Name">NIP: @c.Nip</option>
    }
</datalist>

<datalist id="productOptions">
    @foreach (var p in _availableProducts)
    {
        <option value="@p.Name">@p.Value PLN</option>
    }
</datalist>

@code {
    [Parameter] public int Id { get; set; }

    private ValidatedEditForm<InvoiceDto>? _validatedForm;
    private InvoiceDto _invoice = new() { InvoicePositions = new List<InvoicePositionDto>() };
    private List<ClientDto> _availableClients = new();
    private List<ProductDto> _availableProducts = new();
    private bool _isLoading = true;
    private EditContext? _editContext;

    private readonly IDictionary<string, object> _minOneAttributes = new Dictionary<string, object> { { "min", "1" } };
    private readonly IDictionary<string, object> _priceAttributes = new Dictionary<string, object> { { "step", "0.01" }, { "inputmode", "decimal" } };

    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;
        try
        {
            var inv = await InvoiceService.GetInvoiceByIdAsync(Id);
            if (inv == null) { Navigation.NavigateTo("/invoices"); return; }
            _invoice = inv;
            _invoice.InvoicePositions ??= new List<InvoicePositionDto>();

            var cResp = await ClientService.GetClientsAsync(1, 1000);
            _availableClients = cResp?.Data ?? new();

            var pResp = await ProductService.GetProductsAsync(1, 1000);
            _availableProducts = pResp?.Data ?? new();
        }
        finally { _isLoading = false; }
    }

    private Task OnEditContextInitialized(EditContext ctx)
    {
        _editContext = ctx;
        return Task.CompletedTask;
    }

    private void OnClientNameInput(ChangeEventArgs e)
    {
        var v = e.Value?.ToString();
        _invoice.ClientName = v;
        var match = _availableClients.FirstOrDefault(c => c.Name.Equals(v ?? "", StringComparison.OrdinalIgnoreCase));
        if (match != null)
        {
            _invoice.ClientId = match.ClientId;
            _invoice.ClientName = match.Name;
            _invoice.ClientNip = match.Nip;
            _invoice.ClientEmail = match.Email;
            _invoice.ClientAddress = $"{match.Address.Street} {match.Address.Number}, {match.Address.PostalCode} {match.Address.City}";
        }
        else { _invoice.ClientId = null; }
        _editContext?.NotifyFieldChanged(new FieldIdentifier(_invoice, nameof(_invoice.ClientName)));
    }

    private void OnProductNameInput(ChangeEventArgs e, InvoicePositionDto position)
    {
        var v = e.Value?.ToString();
        position.ProductName = v;
        var match = _availableProducts.FirstOrDefault(p => p.Name.Equals(v ?? "", StringComparison.OrdinalIgnoreCase));
        if (match != null)
        {
            position.ProductId = match.ProductId;
            position.ProductName = match.Name;
            position.ProductValue = match.Value;
            position.ProductDescription = match.Description;
        }
        else { position.ProductId = null; }
        _editContext?.NotifyFieldChanged(new FieldIdentifier(position, nameof(position.ProductName)));
    }

    private void AddPosition() => _invoice.InvoicePositions.Add(new InvoicePositionDto { Quantity = 1, VatRate = "23%" });
    private void RemovePositionWithClear(InvoicePositionDto pos) => _invoice.InvoicePositions.Remove(pos);

    private decimal CalculatePositionVat(InvoicePositionDto pos)
    {
        var net = (pos.ProductValue ?? 0) * pos.Quantity;
        if (pos.VatRate == "zw" || string.IsNullOrEmpty(pos.VatRate) || !pos.VatRate.Contains("%")) return 0;
        decimal.TryParse(pos.VatRate.Replace("%", ""), out var rate);
        return Math.Round(net * (rate / 100m), 2);
    }

    private decimal CalculatePositionGross(InvoicePositionDto pos) => Math.Round(((pos.ProductValue ?? 0) * pos.Quantity) + CalculatePositionVat(pos), 2);
    private decimal CalculateTotalNet() => Math.Round(_invoice.InvoicePositions.Sum(p => (p.ProductValue ?? 0) * p.Quantity), 2);
    private decimal CalculateTotalVat() => Math.Round(_invoice.InvoicePositions.Sum(p => CalculatePositionVat(p)), 2);
    private decimal CalculateTotalGross() => Math.Round(_invoice.InvoicePositions.Sum(p => CalculatePositionGross(p)), 2);

    private string GetFieldClass<T>(System.Linq.Expressions.Expression<Func<T>> accessor)
    {
        if (_editContext == null) return "";
        var fieldId = FieldIdentifier.Create(accessor);
        return _editContext.GetValidationMessages(fieldId).Any() ? "is-invalid" : "is-valid";
    }

    private Task OnInvalidSubmitHandler(EditContext ctx) => Task.CompletedTask;

    private async Task OnSubmitUpdate()
    {
        _invoice.TotalNet = CalculateTotalNet();
        _invoice.TotalVat = CalculateTotalVat();
        _invoice.TotalGross = CalculateTotalGross();

        try
        {
            await InvoiceService.UpdateInvoiceAsync(_invoice);
            Navigation.NavigateTo("/invoices");
        }
        catch (Exception ex)
        {
            _validatedForm?.AddServerError(string.Empty, ex.Message);
        }
    }

    private void OnClientAddressInput(ChangeEventArgs e)
    {
        _invoice.ClientAddress = e.Value?.ToString();
        _editContext?.NotifyFieldChanged(new FieldIdentifier(_invoice, nameof(_invoice.ClientAddress)));
    }

    private void OnSellerAddressInput(ChangeEventArgs e)
    {
        _invoice.SellerAddress = e.Value?.ToString();
        _editContext?.NotifyFieldChanged(new FieldIdentifier(_invoice, nameof(_invoice.SellerAddress)));
    }

    public void Dispose() { _validatedForm = null; }
}