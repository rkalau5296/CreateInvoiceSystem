@page "/invoices/create"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms
@using CreateInvoiceSystem.Frontend.Models
@using CreateInvoiceSystem.Frontend.Services
@using CreateInvoiceSystem.Frontend.Components
@inject InvoiceService InvoiceService
@inject ClientService ClientService
@inject ProductService ProductService
@inject NavigationManager Navigation

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h3 class="mb-0">Nowa Faktura</h3>
            <button class="btn btn-sm btn-outline-light" @onclick='() => Navigation.NavigateTo("/invoices")'>
                <i class="bi bi-arrow-left"></i> Powrót do listy
            </button>
        </div>
        <div class="card-body">
            <ValidatedEditForm TModel="InvoiceDto"
                               Model="_invoice"
                               OnValidSubmit="HandleValidSubmit"
                               OnInvalidSubmit="HandleInvalidSubmit"
                               OnEditContextInitialized="OnEditContextInitialized"
                               @ref="_validatedForm">

                <div class="row mb-4">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Tytuł faktury <span class="text-danger">*</span></label>
                        <ValidatedInputText @bind-Value="_invoice.Title" Placeholder="np. FV 01/2026" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-bold">Data wystawienia <span class="text-danger">*</span></label>
                        <InputDate @bind-Value="_invoice.CreatedDate" class="@FormControlClass(() => _invoice.CreatedDate)" />
                        <ValidationMessage For="@(() => _invoice.CreatedDate)" class="text-danger small" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-bold">Termin płatności <span class="text-danger">*</span></label>
                        <InputDate @bind-Value="_invoice.PaymentDate" class="@FormControlClass(() => _invoice.PaymentDate)" />
                        <ValidationMessage For="@(() => _invoice.PaymentDate)" class="text-danger small" />
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Metoda płatności <span class="text-danger">*</span></label>
                        <InputSelect @bind-Value="_invoice.MethodOfPayment" class="@FormSelectClass(() => _invoice.MethodOfPayment)">
                            <option value="">-- Wybierz --</option>
                            <option value="Przelew">Przelew</option>
                            <option value="Gotówka">Gotówka</option>
                            <option value="BLIK">BLIK</option>
                            <option value="Karta">Karta</option>
                        </InputSelect>
                        <ValidationMessage For="@(() => _invoice.MethodOfPayment)" class="text-danger small" />
                    </div>
                </div>

                <div class="card mb-4 bg-light border-0">
                    <div class="card-body">
                        <h5 class="card-title text-secondary">Dane Nabywcy</h5>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="small fw-bold">Wybierz klienta lub wpisz nową nazwę <span class="text-danger">*</span></label>
                                <input list="clientOptions"
                                       class="@FormControlClass(() => _invoice.ClientName)"
                                       @bind="_invoice.ClientName"
                                       @oninput="(ChangeEventArgs e) => HandleClientChange(e.Value?.ToString())"
                                       placeholder="Nazwa klienta..." />
                                <ValidationMessage For="@(() => _invoice.ClientName)" class="text-danger small" />
                            </div>

                            <div class="col-md-3">
                                <label class="small fw-bold">NIP <span class="text-danger">*</span></label>
                                <ValidatedInputText @bind-Value="_invoice.ClientNip" Placeholder="NIP" />
                            </div>

                            <div class="col-md-3">
                                <label class="small fw-bold">Email klienta</label>
                                <InputText @bind-Value="_invoice.ClientEmail" class="form-control" placeholder="email@klienta.pl" />
                            </div>

                            <div class="col-md-5">
                                <label class="small fw-bold">Ulica <span class="text-danger">*</span></label>
                                <ValidatedInputText @bind-Value="_invoice.Client.Address.Street" Placeholder="Ulica" />
                            </div>
                            <div class="col-md-2">
                                <label class="small fw-bold">Nr domu/lok. <span class="text-danger">*</span></label>
                                <ValidatedInputText @bind-Value="_invoice.Client.Address.Number" Placeholder="Nr" />
                            </div>
                            <div class="col-md-2">
                                <label class="small fw-bold">Kod pocztowy <span class="text-danger">*</span></label>
                                <ValidatedInputText @bind-Value="_invoice.Client.Address.PostalCode" Placeholder="00-000" />
                            </div>
                            <div class="col-md-3">
                                <label class="small fw-bold">Miasto <span class="text-danger">*</span></label>
                                <ValidatedInputText @bind-Value="_invoice.Client.Address.City" Placeholder="Miasto" />
                            </div>
                        </div>
                    </div>
                </div>

                <h5 class="mb-3 text-secondary">Pozycje na fakturze</h5>
                <div class="table-responsive">
                    <table class="table table-bordered align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th style="width:48px">Lp.</th>
                                <th>Produkt / Usługa <span class="text-danger">*</span></th>
                                <th style="width: 110px">Ilość <span class="text-danger">*</span></th>
                                <th style="width: 160px">Cena netto <span class="text-danger">*</span></th>
                                <th style="width: 100px">VAT</th>
                                <th style="width: 130px">Kwota VAT</th>
                                <th style="width: 150px">Wartość BRUTTO</th>
                                <th style="width: 80px"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < _invoice.InvoicePositions.Count; i++)
                            {
                                var pos = _invoice.InvoicePositions[i];
                                <tr @key="pos">
                                    <td>@(i + 1)</td>
                                    <td>
                                        <input list="productOptions"
                                               class="@FormControlClass(() => pos.ProductName)"
                                               @bind="pos.ProductName"
                                               @oninput="(ChangeEventArgs e) => HandleProductChange(pos, e.Value?.ToString())"
                                               placeholder="Nazwa produktu..." />
                                        <ValidationMessage For="@(() => pos.ProductName)" class="text-danger small" />
                                        <div class="mt-2">
                                            <InputTextArea @bind-Value="pos.ProductDescription" class="form-control form-control-sm" placeholder="Opis..." />
                                        </div>
                                    </td>
                                    <td>
                                        <ValidatedInputNumber TValue="int" @bind-Value="pos.Quantity" AdditionalAttributes="@_minOneAttributes" CssClass="@FormControlClass(() => pos.Quantity)" />
                                    </td>
                                    <td>
                                        <ValidatedInputNumber TValue="decimal?" @bind-Value="pos.ProductValue" Step="0.01" AdditionalAttributes="@_priceAttributes" CssClass="@FormControlClass(() => pos.ProductValue)" />
                                    </td>
                                    <td>
                                        <select @bind="pos.VatRate" class="form-select">
                                            <option value="23%">23%</option>
                                            <option value="8%">8%</option>
                                            <option value="5%">5%</option>
                                            <option value="zw">zw</option>
                                            <option value="0%">0%</option>
                                        </select>
                                    </td>
                                    <td class="text-end">@CalculatePositionVat(pos).ToString("N2")</td>
                                    <td class="fw-bold text-end">@CalculatePositionGross(pos).ToString("N2")</td>
                                    <td class="text-center">
                                        <button type="button" class="btn btn-sm btn-danger shadow-sm" @onclick="() => RemovePosition(pos)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <button type="button" class="btn btn-outline-secondary btn-sm mb-4" @onclick="AddPosition">
                    <i class="bi bi-plus-lg"></i> Dodaj pozycję
                </button>

                <div class="d-flex justify-content-end gap-3">
                    <button type="button" class="btn btn-light px-4" @onclick='() => Navigation.NavigateTo("/invoices")'>Anuluj</button>
                    <button type="submit" class="btn btn-success btn-lg px-5 shadow">Zapisz fakturę</button>
                </div>
            </ValidatedEditForm>
        </div>
    </div>
</div>

<datalist id="productOptions">
    @foreach (var p in _availableProducts)
    {
        <option value="@p.Name">@p.Value PLN</option>
    }
</datalist>

<datalist id="clientOptions">
    @foreach (var c in _availableClients)
    {
        <option value="@c.Name">NIP: @c.Nip</option>
    }
</datalist>

@code {
    private InvoiceDto _invoice = new()
    {
        CreatedDate = DateTime.Today,
        PaymentDate = DateTime.Today.AddDays(14),
        InvoicePositions = new List<InvoicePositionDto>(),
        Client = new ClientDto { Address = new AddressDto() }
    };

    private List<ProductDto> _availableProducts = new();
    private List<ClientDto> _availableClients = new();
    private ValidatedEditForm<InvoiceDto>? _validatedForm;
    private EditContext? _editContext;
    private ValidationMessageStore? _pageMessageStore;
    private bool _submitAttempted;
    private string? _pageErrorMessage;
    private bool _pageErrorIsError;

    private readonly IDictionary<string, object> _minOneAttributes = new Dictionary<string, object> { { "min", "1" } };
    private readonly IDictionary<string, object> _priceAttributes = new Dictionary<string, object> { { "step", "0.01" }, { "inputmode", "decimal" } };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var pResponse = await ProductService.GetProductsAsync(1, 1000);
            var cResponse = await ClientService.GetClientsAsync(1, 1000);
            _availableProducts = pResponse?.Data ?? new();
            _availableClients = cResponse?.Data ?? new();

            if (!_invoice.InvoicePositions.Any()) AddPosition();

            _invoice.SellerName ??= "Twoja firma";
            _invoice.SellerNip ??= "0000000000";
            _invoice.SellerAddress ??= "Adres sprzedawcy";
        }
        catch (Exception ex)
        {
            _pageErrorMessage = ex.Message;
            _pageErrorIsError = true;
        }
    }

    private Task OnEditContextInitialized(EditContext ctx)
    {
        _editContext = ctx;
        _pageMessageStore = new ValidationMessageStore(_editContext);
        return Task.CompletedTask;
    }

    private void AddPosition() => _invoice.InvoicePositions.Add(new InvoicePositionDto { Quantity = 1, VatRate = "23%", Product = new ProductDto() });
    private void RemovePosition(InvoicePositionDto pos) => _invoice.InvoicePositions.Remove(pos);

    private decimal CalculatePositionVat(InvoicePositionDto pos)
    {
        var net = (pos.ProductValue ?? 0) * pos.Quantity;
        if (pos.VatRate == "zw" || !pos.VatRate.Contains("%")) return 0;
        decimal.TryParse(pos.VatRate.Replace("%", ""), out var rate);
        return Math.Round(net * (rate / 100m), 2);
    }

    private decimal CalculatePositionGross(InvoicePositionDto pos) => Math.Round(((pos.ProductValue ?? 0) * pos.Quantity) + CalculatePositionVat(pos), 2);

    private void HandleClientChange(string? newValue)
    {
        var match = _availableClients.FirstOrDefault(c => c.Name.Equals(newValue, StringComparison.OrdinalIgnoreCase));
        if (match != null)
        {
            _invoice.ClientId = match.ClientId;
            _invoice.ClientName = match.Name;
            _invoice.ClientNip = match.Nip;
            _invoice.ClientEmail = match.Email;
            _invoice.Client ??= new ClientDto { Address = new AddressDto() };
            _invoice.Client.Address.Street = match.Address.Street;
            _invoice.Client.Address.Number = match.Address.Number;
            _invoice.Client.Address.City = match.Address.City;
            _invoice.Client.Address.PostalCode = match.Address.PostalCode;
            _invoice.Client.Address.Country = match.Address.Country;
            _invoice.ClientAddress = BuildAddressString(_invoice.Client.Address);
        }
        else { _invoice.ClientId = null; }
    }

    private void HandleProductChange(InvoicePositionDto position, string? newValue)
    {
        var match = _availableProducts.FirstOrDefault(p => p.Name.Equals(newValue, StringComparison.OrdinalIgnoreCase));
        if (match != null)
        {
            position.ProductId = match.ProductId;
            position.ProductName = match.Name;
            position.ProductValue = match.Value;
            position.ProductDescription = match.Description;
        }
    }

    private static string BuildAddressString(AddressDto? addr)
    {
        if (addr == null) return "";
        return $"{addr.Street} {addr.Number}, {addr.PostalCode} {addr.City}";
    }

    private string FormControlClass<T>(System.Linq.Expressions.Expression<Func<T>> accessor)
    {
        if (_editContext == null || !_submitAttempted) return "form-control";
        var fieldId = FieldIdentifier.Create(accessor);
        return _editContext.GetValidationMessages(fieldId).Any() ? "form-control is-invalid" : "form-control is-valid";
    }

    private string FormSelectClass<T>(System.Linq.Expressions.Expression<Func<T>> accessor)
    {
        if (_editContext == null || !_submitAttempted) return "form-select";
        var fieldId = FieldIdentifier.Create(accessor);
        return _editContext.GetValidationMessages(fieldId).Any() ? "form-select is-invalid" : "form-select is-valid";
    }

    private async Task HandleValidSubmit() { _submitAttempted = true; await ValidateAndSubmit(); }
    private async Task HandleInvalidSubmit(EditContext ctx) { _submitAttempted = true; await ValidateAndSubmit(); }

    private async Task ValidateAndSubmit()
    {
        if (_invoice.Client?.Address != null)
            _invoice.ClientAddress = BuildAddressString(_invoice.Client.Address);

        _invoice.TotalNet = _invoice.InvoicePositions.Sum(p => (p.ProductValue ?? 0) * p.Quantity);
        _invoice.TotalVat = _invoice.InvoicePositions.Sum(p => CalculatePositionVat(p));
        _invoice.TotalGross = _invoice.TotalNet + _invoice.TotalVat;

        if (_invoice.ClientId == null && _invoice.Client != null)
        {
            _invoice.Client.Name = _invoice.ClientName;
            _invoice.Client.Nip = _invoice.ClientNip;
            _invoice.Client.Email = _invoice.ClientEmail;
        }

        try
        {
            var result = await InvoiceService.SaveInvoiceAsync(_invoice);
            if (result != null) Navigation.NavigateTo("/invoices");
        }
        catch (Exception ex)
        {
            _pageErrorMessage = ex.Message;
            _pageErrorIsError = true;
        }
    }
}