@page "/invoices/create"
@using CreateInvoiceSystem.Frontend.Models
@using CreateInvoiceSystem.Frontend.Services
@using CreateInvoiceSystem.Frontend.Components
@using System.ComponentModel.DataAnnotations
@using System.Globalization
@inject InvoiceService InvoiceService
@inject ClientService ClientService
@inject ProductService ProductService
@inject NavigationManager Navigation

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h3 class="mb-0">Nowa Faktura</h3>
            <button class="btn btn-sm btn-outline-light" type="button" @onclick='() => Navigation.NavigateTo("/invoices")'>
                <i class="bi bi-arrow-left"></i> Powrót do listy
            </button>
        </div>
        <div class="card-body">

            @if (_errorMessage != null)
            {
                <div class="alert alert-danger">@_errorMessage</div>
            }

            <div class="row mb-4">
                <div class="col-md-6">
                    <label class="form-label fw-bold">Tytuł faktury <span class="text-danger">*</span></label>
                    <SimpleTextInput Value="@_title"
                                     ValueChanged="v => { _title = v; Touch(nameof(_title)); }"
                                     IsActive="@IsActive(nameof(_title))"
                                     Placeholder="np. FV 01/2026"
                                     ErrorMessage="Tytuł faktury jest wymagany" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">Data wystawienia <span class="text-danger">*</span></label>
                    <SimpleTextInput Value="@_createdDate"
                                     ValueChanged="v => { _createdDate = v; Touch(nameof(_createdDate)); }"
                                     IsActive="@IsActive(nameof(_createdDate))"
                                     Type="date"
                                     ErrorMessage="Data wystawienia jest wymagana" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">Termin płatności <span class="text-danger">*</span></label>
                    <SimpleTextInput Value="@_paymentDate"
                                     ValueChanged="v => { _paymentDate = v; Touch(nameof(_paymentDate)); }"
                                     IsActive="@IsActive(nameof(_paymentDate))"
                                     Type="date"
                                     ErrorMessage="Termin płatności jest wymagany" />
                </div>
            </div>

            <div class="row mb-4">
                <div class="col-md-4">
                    <label class="form-label fw-bold">Metoda płatności <span class="text-danger">*</span></label>
                    <SimpleSelect Value="@_methodOfPayment"
                                  ValueChanged="v => { _methodOfPayment = v; Touch(nameof(_methodOfPayment)); }"
                                  IsActive="@IsActive(nameof(_methodOfPayment))"
                                  ErrorMessage="Metoda płatności jest wymagana">
                        <option value="">-- Wybierz --</option>
                        <option value="Przelew">Przelew</option>
                        <option value="Gotówka">Gotówka</option>
                        <option value="BLIK">BLIK</option>
                        <option value="Karta">Karta</option>
                    </SimpleSelect>
                </div>
            </div>

            <div class="card mb-4 bg-light border-0">
                <div class="card-body">
                    <h5 class="card-title text-secondary">Dane Nabywcy</h5>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="small fw-bold">Wybierz klienta lub wpisz nową nazwę <span class="text-danger">*</span></label>
                            <SimpleTextInput Value="@_clientName"
                                             ValueChanged="v => { _clientName = v; Touch(nameof(_clientName)); OnClientInput(v); }"
                                             IsActive="@IsActive(nameof(_clientName))"
                                             DataList="clientOptions"
                                             Placeholder="Nazwa klienta..."
                                             ErrorMessage="Nazwa klienta jest wymagana" />
                        </div>
                        <div class="col-md-3">
                            <label class="small fw-bold">NIP <span class="text-danger">*</span></label>
                            <SimpleTextInput Value="@_clientNip"
                                             ValueChanged="v => { _clientNip = v; Touch(nameof(_clientNip)); }"
                                             IsActive="@IsActive(nameof(_clientNip))"
                                             Placeholder="NIP"
                                             ErrorMessage="NIP klienta jest wymagany" />
                        </div>
                        <div class="col-md-3">
                            <label class="small fw-bold">Email klienta</label>
                            <input class="form-control" value="@_clientEmail" placeholder="email@klienta.pl"
                                   @oninput="e => _clientEmail = e.Value?.ToString()" />
                        </div>
                        <div class="col-md-5">
                            <label class="small fw-bold">Ulica <span class="text-danger">*</span></label>
                            <SimpleTextInput Value="@_street"
                                             ValueChanged="v => { _street = v; Touch(nameof(_street)); }"
                                             IsActive="@IsActive(nameof(_street))"
                                             Placeholder="Ulica"
                                             ErrorMessage="Ulica jest wymagana" />
                        </div>
                        <div class="col-md-2">
                            <label class="small fw-bold">Nr domu/lok. <span class="text-danger">*</span></label>
                            <SimpleTextInput Value="@_streetNumber"
                                             ValueChanged="v => { _streetNumber = v; Touch(nameof(_streetNumber)); }"
                                             IsActive="@IsActive(nameof(_streetNumber))"
                                             Placeholder="Nr"
                                             ErrorMessage="Numer domu/lokalu jest wymagany" />
                        </div>
                        <div class="col-md-2">
                            <label class="small fw-bold">Kod pocztowy <span class="text-danger">*</span></label>
                            <SimpleTextInput Value="@_postalCode"
                                             ValueChanged="v => { _postalCode = v; Touch(nameof(_postalCode)); }"
                                             IsActive="@IsActive(nameof(_postalCode))"
                                             Placeholder="00-000"
                                             ErrorMessage="Kod pocztowy jest wymagany" />
                        </div>
                        <div class="col-md-3">
                            <label class="small fw-bold">Miasto <span class="text-danger">*</span></label>
                            <SimpleTextInput Value="@_city"
                                             ValueChanged="v => { _city = v; Touch(nameof(_city)); }"
                                             IsActive="@IsActive(nameof(_city))"
                                             Placeholder="Miasto"
                                             ErrorMessage="Miasto jest wymagane" />
                        </div>
                    </div>
                </div>
            </div>

            <h5 class="mb-3 text-secondary">Pozycje na fakturze</h5>
            <div class="table-responsive">
                <table class="table table-bordered align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th style="width:48px">Lp.</th>
                            <th>Produkt / Usługa <span class="text-danger">*</span></th>
                            <th style="width:110px">Ilość <span class="text-danger">*</span></th>
                            <th style="width:160px">Cena netto <span class="text-danger">*</span></th>
                            <th style="width:100px">VAT</th>
                            <th style="width:130px">Kwota VAT</th>
                            <th style="width:150px">Wartość BRUTTO</th>
                            <th style="width:80px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < _positions.Count; i++)
                        {
                            var pos = _positions[i];
                            var idx = i;
                            <tr @key="pos.Id">
                                <td>@(idx + 1)</td>
                                <td>
                                    <SimpleTextInput Value="@pos.ProductName"
                                                     ValueChanged="v => { pos.ProductName = v; TouchPos(pos, nameof(pos.ProductName)); OnProductInput(pos, v); }"
                                                     IsActive="@IsActivePos(pos, nameof(pos.ProductName))"
                                                     DataList="productOptions"
                                                     Placeholder="Nazwa produktu..."
                                                     ErrorMessage="Nazwa produktu jest wymagana" />
                                    <div class="mt-2">
                                        <textarea class="form-control form-control-sm" placeholder="Opis..."
                                                  @oninput="e => pos.ProductDescription = e.Value?.ToString() ?? string.Empty">@pos.ProductDescription</textarea>
                                    </div>
                                </td>
                                <td>
                                    <SimpleIntInput Value="@pos.Quantity"
                                                    ValueChanged="v => { pos.Quantity = v; TouchPos(pos, nameof(pos.Quantity)); }"
                                                    IsActive="@IsActivePos(pos, nameof(pos.Quantity))"
                                                    Min="1"
                                                    ErrorMessage="Ilość jest wymagana" />
                                </td>
                                <td>
                                    <SimpleDecimalInput Value="@pos.ProductValue"
                                                        ValueChanged="v => { pos.ProductValue = v; TouchPos(pos, nameof(pos.ProductValue)); }"
                                                        StringValue="@pos.ProductValueString"
                                                        StringValueChanged="s => pos.ProductValueString = s"
                                                        IsActive="@IsActivePos(pos, nameof(pos.ProductValue))"
                                                        ErrorMessage="Cena produktu jest wymagana" />
                                </td>
                                <td>
                                    <select class="form-select" @onchange="e => OnVatChanged(pos, e)">
                                        <option value="23%" selected="@(pos.VatRate == "23%")">23%</option>
                                        <option value="8%" selected="@(pos.VatRate == "8%")">8%</option>
                                        <option value="5%" selected="@(pos.VatRate == "5%")">5%</option>
                                        <option value="zw" selected="@(pos.VatRate == "zw")">zw</option>
                                        <option value="0%" selected="@(pos.VatRate == "0%")">0%</option>
                                    </select>
                                </td>
                                <td class="text-end">@CalcVat(pos).ToString("N2")</td>
                                <td class="fw-bold text-end">@CalcGross(pos).ToString("N2")</td>
                                <td class="text-center">
                                    <button type="button" class="btn btn-sm btn-danger px-3 shadow-sm" @onclick="() => _positions.Remove(pos)">
                                        <i class="bi bi-trash me-1"></i> Usuń
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <button type="button" class="btn btn-outline-secondary btn-sm mb-4" @onclick="AddPosition">
                <i class="bi bi-plus-lg"></i> Dodaj pozycję
            </button>

            <div class="d-flex justify-content-end gap-3">
                <button type="button" class="btn btn-light px-4" @onclick='() => Navigation.NavigateTo("/invoices")'>Anuluj</button>
                <button type="button" class="btn btn-success btn-lg px-5 shadow" @onclick="HandleSave" disabled="@_isSaving">
                @if (_isSaving)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                    <span>Zapisywanie...</span>
                }
                else
                {
                    <span>Zapisz fakturę</span>
                }
            </button>
            </div>

        </div>
    </div>
</div>

<datalist id="productOptions">
    @foreach (var p in _availableProducts)
    {
        <option value="@p.Name">@p.Value PLN</option>
    }
</datalist>

<datalist id="clientOptions">
    @foreach (var c in _availableClients)
    {
        <option value="@c.Name">NIP: @c.Nip</option>
    }
</datalist>

@code {
    private string? _title;
    private string? _createdDate = DateTime.Today.ToString("yyyy-MM-dd");
    private string? _paymentDate = DateTime.Today.AddDays(14).ToString("yyyy-MM-dd");
    private string? _methodOfPayment;
    private string? _clientName;
    private string? _clientNip;
    private string? _clientEmail;
    private string? _street;
    private string? _streetNumber;
    private string? _postalCode;
    private string? _city;
    private int? _selectedClientId;
    private bool _isSaving;

    private List<PositionRow> _positions = new();
    private List<ProductDto> _availableProducts = new();
    private List<ClientDto> _availableClients = new();
    private string? _errorMessage;
    private HashSet<string> _touched = new();
    private bool _submitAttempted;

    private class PositionRow
    {
        public Guid Id { get; } = Guid.NewGuid();
        public string? ProductName { get; set; }
        public string ProductDescription { get; set; } = string.Empty;
        public int Quantity { get; set; } = 1;
        public decimal? ProductValue { get; set; }
        public string ProductValueString { get; set; } = string.Empty;
        public string VatRate { get; set; } = "23%";
        public int? ProductId { get; set; }
        public HashSet<string> Touched { get; } = new();
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var pResp = await ProductService.GetProductsAsync(1, 1000);
            var cResp = await ClientService.GetClientsAsync(1, 1000);
            _availableProducts = pResp?.Data ?? new();
            _availableClients = cResp?.Data ?? new();
        }
        catch (Exception ex) { _errorMessage = ex.Message; }

        AddPosition();
    }

    private void AddPosition() => _positions.Add(new PositionRow());
    private void Touch(string field) => _touched.Add(field);
    private void TouchPos(PositionRow pos, string field) => pos.Touched.Add(field);
    private bool IsActive(string field) => _submitAttempted || _touched.Contains(field);
    private bool IsActivePos(PositionRow pos, string field) => _submitAttempted || pos.Touched.Contains(field);

    private void OnVatChanged(PositionRow pos, ChangeEventArgs e)
    {
        pos.VatRate = e.Value?.ToString() ?? "23%";
    }

    private decimal CalcVat(PositionRow pos)
    {
        var net = (pos.ProductValue ?? 0) * pos.Quantity;
        if (pos.VatRate == "zw" || !pos.VatRate.Contains("%")) return 0;
        decimal.TryParse(pos.VatRate.Replace("%", ""), out var rate);
        return Math.Round(net * (rate / 100m), 2);
    }

    private decimal CalcGross(PositionRow pos) =>
        Math.Round((pos.ProductValue ?? 0) * pos.Quantity + CalcVat(pos), 2);

    private void OnClientInput(string? value)
    {
        var match = _availableClients.FirstOrDefault(c => c.Name.Equals(value, StringComparison.OrdinalIgnoreCase));
        if (match != null)
        {
            _selectedClientId = match.ClientId;
            _clientNip = match.Nip;
            _clientEmail = match.Email;
            _street = match.Address.Street;
            _streetNumber = match.Address.Number;
            _postalCode = match.Address.PostalCode;
            _city = match.Address.City;
            Touch(nameof(_clientNip));
            Touch(nameof(_street));
            Touch(nameof(_streetNumber));
            Touch(nameof(_postalCode));
            Touch(nameof(_city));
        }
        else
        {
            _selectedClientId = null;
        }
    }

    private void OnProductInput(PositionRow pos, string? value)
    {
        var match = _availableProducts.FirstOrDefault(p => p.Name.Equals(value, StringComparison.OrdinalIgnoreCase));
        if (match != null)
        {
            pos.ProductId = match.ProductId;
            pos.ProductValue = match.Value;
            pos.ProductValueString = match.Value?.ToString(CultureInfo.InvariantCulture) ?? string.Empty;
            pos.ProductDescription = match.Description;
            TouchPos(pos, nameof(pos.ProductValue));
        }
    }

    private bool IsValid()
    {
        if (string.IsNullOrWhiteSpace(_title)) return false;
        if (string.IsNullOrWhiteSpace(_createdDate)) return false;
        if (string.IsNullOrWhiteSpace(_paymentDate)) return false;
        if (string.IsNullOrWhiteSpace(_methodOfPayment)) return false;
        if (string.IsNullOrWhiteSpace(_clientName)) return false;
        if (string.IsNullOrWhiteSpace(_clientNip)) return false;
        if (string.IsNullOrWhiteSpace(_street)) return false;
        if (string.IsNullOrWhiteSpace(_streetNumber)) return false;
        if (string.IsNullOrWhiteSpace(_postalCode)) return false;
        if (string.IsNullOrWhiteSpace(_city)) return false;
        if (!_positions.Any()) return false;
        foreach (var pos in _positions)
        {
            if (string.IsNullOrWhiteSpace(pos.ProductName)) return false;
            if (pos.Quantity < 1) return false;
            if (pos.ProductValue == null || pos.ProductValue <= 0) return false;
        }
        return true;
    }

    private async Task HandleSave()
    {
        if (_isSaving) return;
        _isSaving = true;

        try
        {
            _submitAttempted = true;
            foreach (var pos in _positions)
            {
                TouchPos(pos, nameof(pos.ProductName));
                TouchPos(pos, nameof(pos.Quantity));
                TouchPos(pos, nameof(pos.ProductValue));
            }
            if (!IsValid()) return;

            try
            {
                DateTime.TryParse(_createdDate, out var created);
                created = DateTime.SpecifyKind(created, DateTimeKind.Local);
                DateTime.TryParse(_paymentDate, out var payment);  
                payment = DateTime.SpecifyKind(payment, DateTimeKind.Local);
                var invoice = new InvoiceDto
                {
                    Title = _title!,
                    CreatedDate = created,
                    PaymentDate = payment,
                    MethodOfPayment = _methodOfPayment!,
                    ClientId = _selectedClientId,
                    ClientName = _clientName,
                    ClientNip = _clientNip,
                    ClientEmail = _clientEmail,
                    ClientAddress = $"{_street} {_streetNumber}, {_postalCode} {_city}",
                    Client = new ClientDto
                    {
                        ClientId = _selectedClientId ?? 0,
                        Name = _clientName!,
                        Nip = _clientNip!,
                        Email = _clientEmail ?? string.Empty,
                        Address = new AddressDto
                        {
                            Street = _street!,
                            Number = _streetNumber!,
                            PostalCode = _postalCode!,
                            City = _city!
                        }
                    },
                    SellerName = "Twoja firma",
                    SellerNip = "0000000000",
                    SellerAddress = "Adres sprzedawcy",
                    InvoicePositions = _positions.Select(p => new InvoicePositionDto
                    {
                        ProductId = p.ProductId,
                        ProductName = p.ProductName,
                        ProductDescription = p.ProductDescription,
                        Quantity = p.Quantity,
                        ProductValue = p.ProductValue,
                        VatRate = p.VatRate
                    }).ToList()
                };
                invoice.TotalNet = invoice.InvoicePositions.Sum(p => (p.ProductValue ?? 0) * p.Quantity);
                invoice.TotalVat = invoice.InvoicePositions.Sum(p =>
                {
                    var net = (p.ProductValue ?? 0) * p.Quantity;
                    if (p.VatRate == "zw" || !p.VatRate.Contains("%")) return 0;
                    decimal.TryParse(p.VatRate.Replace("%", ""), out var rate);
                    return Math.Round(net * (rate / 100m), 2);
                });
                invoice.TotalGross = invoice.TotalNet + invoice.TotalVat;
                var result = await InvoiceService.SaveInvoiceAsync(invoice);
                if (result != null) Navigation.NavigateTo("/invoices");
            }
            catch (Exception ex)
            {
                _errorMessage = ex.Message;
            }
        }
        finally
        {
            _isSaving = false;
        }
    }
}