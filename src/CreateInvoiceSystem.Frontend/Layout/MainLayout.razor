@inherits LayoutComponentBase
@implements IDisposable
@inject NavigationManager Navigation
@using CreateInvoiceSystem.Frontend.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthService AuthService
@inject IJSRuntime JS

<div class="page">
    <AuthorizeView>
        <Authorized>
            <div class="sidebar d-flex flex-column" style="background: #2c3e50; color: white; min-width: 250px; height: 100vh;">
                <div class="top-row ps-3 navbar navbar-dark">
                    <a class="navbar-brand" href="dashboard">System Faktur</a>
                </div>

                <nav class="flex-column p-3 flex-grow-1">
                    <div class="nav-item px-3 mb-2">
                        <NavLink class="nav-link text-white" href="dashboard">
                            🏠 Dashboard
                        </NavLink>
                    </div>
                    <div class="nav-item px-3 mb-2">
                        <NavLink class="nav-link text-white" href="invoices">
                            📄 Faktury
                        </NavLink>
                    </div>
                    <div class="nav-item px-3 mb-2">
                        <NavLink class="nav-link text-white" href="clients">
                            👥 Klienci
                        </NavLink>
                    </div>
                    <div class="nav-item px-3 mb-2">
                        <NavLink class="nav-link text-white" href="products">
                            📦 Produkty
                        </NavLink>
                    </div>
                    <div class="nav-item px-3 mb-2">
                        <NavLink class="nav-link text-white" href="nbp-rates">
                            💰 Kursy NBP
                        </NavLink>
                    </div>
                </nav>

                <div class="mt-auto p-3 border-top border-secondary">
                    <div class="nav-item px-3 mb-1">
                        <NavLink class="nav-link text-white-50 small" href="settings">
                            ⚙️ Ustawienia
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <button class="btn btn-link nav-link text-danger small w-100 text-start p-0 border-0 shadow-none"
                                @onclick="HandleLogout">
                            🚪 Wyloguj się
                        </button>
                    </div>
                </div>
            </div>
        </Authorized>
    </AuthorizeView>

    <main>
        <div class="top-row px-4">
        </div>

        @if (!string.IsNullOrEmpty(_globalStatusMessage))
        {
            <div class="container">
                <div class="alert alert-danger mt-2 mb-2" role="alert">
                    @_globalStatusMessage
                </div>
            </div>
        }

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    private string? _globalStatusMessage;

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
        _ = CheckSessionMessageAsync();
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        _ = CheckSessionMessageAsync();
    }

    private async Task CheckSessionMessageAsync()
    {
        try
        {
            var msg = await JS.InvokeAsync<string>("sessionStorage.getItem", "sessionExpiredMessage");
            if (!string.IsNullOrWhiteSpace(msg))
            {
                _globalStatusMessage = msg;
                await JS.InvokeVoidAsync("sessionStorage.removeItem", "sessionExpiredMessage");
                StateHasChanged();
            }
            else
            {
                _globalStatusMessage = null;
                StateHasChanged();
            }
        }
        catch
        {
        }
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }

    private async Task HandleLogout()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/", forceLoad: true);
    }
}